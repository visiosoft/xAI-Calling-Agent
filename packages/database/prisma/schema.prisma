generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Multi-tenancy ───

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  passwordHash   String?
  emailVerified  DateTime?
  image          String?
  role           UserRole  @default(MEMBER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  @@index([organizationId])
}

model Organization {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  plan               PlanTier @default(FREE)
  xaiApiKey          String?
  maxConcurrentCalls Int      @default(5)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users           User[]
  providerConfigs ProviderConfig[]
  agents          Agent[]
  contactLists    ContactList[]
  campaigns       Campaign[]
  calls           Call[]
}

model ProviderConfig {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       TelephonyProvider
  accountSid     String
  authToken      String
  phoneNumbers   String[]
  isDefault      Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, provider])
  @@index([organizationId])
}

enum TelephonyProvider {
  TWILIO
  TELNYX
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ─── AI Agent Configuration ───

model Agent {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  name            String
  systemPrompt    String   @db.Text
  voice           String   @default("alloy")
  languageHint    String?
  turnDetection   Json?
  tools           Json?
  greeting        String?  @db.Text
  maxCallDuration Int      @default(300)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaigns Campaign[]

  @@index([organizationId])
}

// ─── Contacts ───

model ContactList {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  contactCount   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contacts  Contact[]
  campaigns Campaign[]

  @@index([organizationId])
}

model Contact {
  id            String      @id @default(cuid())
  contactListId String
  contactList   ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  phoneNumber   String
  firstName     String?
  lastName      String?
  email         String?
  customFields  Json?
  timezone      String?
  doNotCall     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  calls Call[]

  @@index([contactListId])
  @@index([phoneNumber])
}

// ─── Campaigns ───

model Campaign {
  id                 String         @id @default(cuid())
  organizationId     String
  organization       Organization   @relation(fields: [organizationId], references: [id])
  agentId            String
  agent              Agent          @relation(fields: [agentId], references: [id])
  contactListId      String
  contactList        ContactList    @relation(fields: [contactListId], references: [id])
  name               String
  status             CampaignStatus @default(DRAFT)
  maxConcurrentCalls Int            @default(3)
  callsPerMinute     Int            @default(2)
  retryAttempts      Int            @default(2)
  retryDelayMinutes  Int            @default(30)
  scheduledStart     DateTime?
  scheduledEnd       DateTime?
  callerIdNumber     String
  totalContacts      Int            @default(0)
  completedCalls     Int            @default(0)
  successfulCalls    Int            @default(0)
  failedCalls        Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  startedAt          DateTime?
  completedAt        DateTime?

  calls Call[]

  @@index([organizationId])
  @@index([status])
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

// ─── Calls ───

model Call {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  campaignId      String
  campaign        Campaign     @relation(fields: [campaignId], references: [id])
  contactId       String
  contact         Contact      @relation(fields: [contactId], references: [id])
  twilioCallSid   String?      @unique
  twilioStreamSid String?
  status          CallStatus   @default(QUEUED)
  outcome         CallOutcome?
  direction       String       @default("outbound")
  fromNumber      String
  toNumber        String
  duration        Int?
  startedAt       DateTime?
  answeredAt      DateTime?
  endedAt         DateTime?
  recordingUrl    String?
  transcript      Json?
  summary         String?      @db.Text
  sentiment       String?
  toolCallResults Json?
  errorMessage    String?
  retryCount      Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([campaignId])
  @@index([status])
  @@index([twilioCallSid])
}

enum CallStatus {
  QUEUED
  INITIATING
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  NO_ANSWER
  BUSY
  CANCELLED
}

enum CallOutcome {
  INTERESTED
  NOT_INTERESTED
  APPOINTMENT_BOOKED
  CALLBACK_REQUESTED
  VOICEMAIL
  DO_NOT_CALL
  WRONG_NUMBER
  COMPLETED_SURVEY
  OTHER
}

// ─── NextAuth.js ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token])
}
